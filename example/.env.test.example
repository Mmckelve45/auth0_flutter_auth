# ============================================================
# Auth0 Integration Test Configuration
# ============================================================
# Copy this file to .env.test and fill in your Auth0 tenant details.
# .env.test is gitignored and will NOT be committed.
#
# TENANT SETUP:
# 1. Create a "Native" application in your Auth0 dashboard
# 2. Enable "Password" grant type on the application
# 3. Enable a database connection (e.g. Username-Password-Authentication)
# 4. Create a test user in that connection
# 5. (Optional) For MFA tests: enroll a second user in TOTP MFA
#    and save the TOTP secret (base32 string from the QR code)
# ============================================================

AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CONNECTION=Username-Password-Authentication

# Primary test user (must exist in the database connection above)
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=SecureP@ssw0rd!

# MFA test user (optional — enrolled in TOTP MFA)
TEST_MFA_USER_EMAIL=mfa-testuser@example.com
TEST_MFA_USER_PASSWORD=SecureMfaP@ss!
TEST_MFA_TOTP_SECRET=JBSWY3DPEHPK3PXP
