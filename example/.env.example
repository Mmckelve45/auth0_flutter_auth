# Copy this file to .env and fill in your Auth0 credentials.
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id

# Mobile: custom URL scheme registered in Info.plist / AndroidManifest.xml.
# The SDK builds redirect URLs as {scheme}:/callback and {scheme}:/logout.
AUTH0_MOBILE_CALLBACK_SCHEME=com.yourcompany.app

# Web: full redirect URL (must match Allowed Callback URLs in Auth0 Dashboard).
AUTH0_WEB_REDIRECT_URL=http://localhost:5000/callback
